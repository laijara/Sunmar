{
  "name": "interns-landings",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "rewrite:images": "node src/lib/rewriteAssetsBuild.mjs",
    "cdn": "node src/lib/cdn-server.mjs",
    "gen:markup": "node src/lib/gen-markup-index.mjs",
    "gen:scripts": "node src/lib/gen-scripts-index.mjs",
    "gen:styles": "node src/lib/gen-styles-index.mjs",
    "gen:markup:watch": "node src/lib/gen-markup-index.mjs --watch",
    "gen:scripts:watch": "node src/lib/gen-scripts-index.mjs --watch",
    "gen:styles:watch": "node src/lib/gen-styles-index.mjs --watch",
    "gen:all": "npm run gen:markup && npm run gen:scripts && npm run gen:styles",
    "dev": "npm run gen:all && concurrently -n MARKUP,SCRIPTS,STYLES,CDN,VITE -c auto \"npm:gen:markup:watch\" \"npm:gen:scripts:watch\" \"npm:gen:styles:watch\" \"npm:cdn\" \"vite\"",
    "check": "node src/lib/check-assets-prefix.mjs",
    "block:add": "node src/lib/block-add.mjs",
    "block:rename": "node src/lib/block-rename.mjs",
    "build": "node src/lib/build-cms.mjs && node src/lib/rewriteAssetsBuild.mjs"
  },
  "devDependencies": {
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "sass": "^1.97.3",
    "vite": "^8.1.4",
    "vite-plugin-monkey": "^8.0.6"
  },
  "dependencies": {
    "@coraltravelcenter/corallium": "^1.0.5",
    "@vitejs/plugin-vue": "^6.0.3",
    "accordion-js": "^3.4.1",
    "express": "^5.2.1",
    "swiper": "^12.1.0"
  }
}
